__pycache__/
*.py[cod]
.venv/
venv/

# Environment
.env


# Data — input, output, and runtime state (ignore contents, keep folders)
data/raw/*
!data/raw/.gitkeep
data/processed/*
!data/processed/.gitkeep
data/logs/*.log
data/logs/dead_letter/*
!data/logs/dead_letter/.gitkeep


# Database runtime files (the SCHEMA script in /database is tracked)
data/db.sqlite3
*.sql.bak
*.dump
# /database/*.sql is INTENTIONALLY tracked — do not add *.sql here


# Node / frontend (preventive)
node_modules/
npm-debug.log*


# OS + editor
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp


# Testing
.pytest_cache/